# Python — anchored to repo root so they don't shadow `web/lib/`,
# `web/dist/`, etc. when JS/TS workspaces land.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtualenvs / managers
.venv/
venv/
env/
.env
.env.local
.env.*.local
.python-version
.uv/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
