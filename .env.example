# Aeroza environment configuration
# Copy to .env for local development; never commit .env.

# ---- Application ----
AEROZA_ENV=development
AEROZA_LOG_LEVEL=INFO
AEROZA_HOST=0.0.0.0
AEROZA_PORT=8000

# ---- Postgres + PostGIS ----
AEROZA_DATABASE_URL=postgresql+asyncpg://aeroza:aeroza@localhost:5432/aeroza

# ---- Redis ----
AEROZA_REDIS_URL=redis://localhost:6379/0

# ---- NATS JetStream ----
AEROZA_NATS_URL=nats://localhost:4222

# ---- Object storage (S3 / R2) ----
# Leave blank in dev to disable; set when ingest pipeline is wired up.
AEROZA_S3_ENDPOINT=
AEROZA_S3_BUCKET=
AEROZA_S3_ACCESS_KEY_ID=
AEROZA_S3_SECRET_ACCESS_KEY=
AEROZA_S3_REGION=us-east-1

# ---- Auth (placeholder) ----
AEROZA_API_KEY_SALT=replace-me-with-random-32-bytes

# ---- APNs (severe-weather push) ----
# Token-based Apple Push auth. Create the key at developer.apple.com →
# Certificates, Identifiers & Profiles → Keys → APNs; download the .p8 ONCE.
# Never commit the .p8. Leave blank to disable push (dispatch becomes a no-op).
AEROZA_APNS_KEY_ID=
AEROZA_APNS_TEAM_ID=5M9UT7VQ8Q
# Either the raw PEM or a single-line base64 of the .p8 (base64 is easiest in a
# .env / Railway var: `base64 -i AuthKey_XXXX.p8`).
AEROZA_APNS_PRIVATE_KEY=
AEROZA_APNS_TOPIC=app.aeroza.AerozaOne
# false → api.push.apple.com (TestFlight/App Store); true → sandbox (debug builds).
AEROZA_APNS_USE_SANDBOX=false
# Base URL the push tells the iOS extension to call for rich hydration.
AEROZA_PUBLIC_API_BASE_URL=https://api.aeroza.app
